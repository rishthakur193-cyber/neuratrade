# Server Configuration
PORT=8080
NODE_ENV=production

# Database
# Use a PostgreSQL connection string for production
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public"

# Security
JWT_SECRET="generate-a-long-random-string-for-production"

# Broker APIs
# Zerodha Kite Connect
ZERODHA_API_KEY=
ZERODHA_API_SECRET=

# Angel One SmartAPI
ANGEL_ONE_API_KEY=
ANGEL_ONE_CLIENT_CODE=
ANGEL_ONE_PASSWORD=
ANGEL_ONE_TOTP_SECRET=

# Dhan API
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=

# Redis (Optional but recommended for performance)
REDIS_URL=
