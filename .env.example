# Relational DB (PostgreSQL)
# Format: postgres://user:password@host:port/database?schema=public
DATABASE_URL="postgres://user:pass@host:5432/neuratrade?schema=public"

# Live Brokerage Variables
# Your Angel One API key generated from the SmartAPI dashboard
SMARTAPI_API_KEY="your-angel-one-api-key"

# JWT Matrix
# A long, random string used to sign JWT tokens
NEXTAUTH_SECRET="strict-cryptographic-secret-generate-with-openssl"

# Transactional EMail Array (Nodemailer config)
SMTP_HOST="smtp.mailgun.org"
SMTP_PORT="587"
SMTP_SECURE="true"
SMTP_USER="postmaster@your.domain"
SMTP_PASS="smtp_password"
SMTP_FROM='"NeuraTrade Engine" <noreply@neuratrade.ecosystem>'

# Optional: Google Gemini API Key for the 8 Pillars Analysis AI
GOOGLE_GEMINI_API_KEY="your-gemini-api-key"
